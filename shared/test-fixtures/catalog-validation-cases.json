  "launchCatalogValidationRules": {
    "description": "Rules from DomainSchema.md §12 that every launch catalog entry must pass, plus the structural shape invariants enforced by LaunchPresetFilmCatalogShapeTests and the loader's validateProfileShape.",
    "rules": [
      {
        "id": "rule-1",
        "description": "The film identity array is non-empty",
        "field": null,
        "constraint": "array.count > 0"
      },
      {
        "id": "rule-2",
        "description": "Every identity has a non-empty id, unique across the catalog",
        "field": "id",
        "constraint": "nonEmpty && unique"
      },
      {
        "id": "rule-3",
        "description": "Every identity has a non-empty canonicalStockName, unique across the catalog",
        "field": "canonicalStockName",
        "constraint": "nonEmpty && unique"
      },
      {
        "id": "rule-4",
        "description": "Every identity has kind = preset",
        "field": "kind",
        "constraint": "equals",
        "expectedValue": "preset"
      },
      {
        "id": "rule-5",
        "description": "Every identity has productionStatus = current",
        "field": "productionStatus",
        "constraint": "equals",
        "expectedValue": "current"
      },
      {
        "id": "rule-5a",
        "description": "Every identity has positive iso (box-speed ISO)",
        "field": "iso",
        "constraint": "> 0"
      },
      {
        "id": "rule-6",
        "description": "Every identity has exactly one profile",
        "field": "profiles",
        "constraint": "array.count == 1"
      },
      {
        "id": "rule-7",
        "description": "Every profile source has kind = manufacturerPublished",
        "field": "profiles[0].source.kind",
        "constraint": "equals",
        "expectedValue": "manufacturerPublished"
      },
      {
        "id": "rule-8",
        "description": "Every profile source has authority = official",
        "field": "profiles[0].source.authority",
        "constraint": "equals",
        "expectedValue": "official"
      },
      {
        "id": "rule-9",
        "description": "Every profile has at least one rule, and every rule decodes to a known variant",
        "field": "profiles[0].rules",
        "constraint": "array.count >= 1 && allKnownVariants"
      },
      {
        "id": "rule-10",
        "description": "No launch preset profile carries the legacy table rule kind. The domain no longer models a calculation table rule; future custom / user-defined table input is outside the launch preset scope.",
        "field": "profiles[0].rules[*].kind",
        "constraint": "noneEquals",
        "forbiddenValue": "table"
      },
      {
        "id": "rule-11",
        "description": "Every launch preset profile matches one of the two allowed shapes: (a) official quantified formula (formula rule only, with optional sourceEvidence; PTIMER-160 retired the companion threshold rule — the formula owns its no-correction and source-range guards), (b) official limited guidance (threshold + limitedGuidance, no formula, empty sourceEvidence). Unofficial practical formula profiles are bundled outside the launch catalog file (DomainSchema §13.3) and are not validated by this rule.",
        "field": "profiles[0]",
        "constraint": "matchesAllowedShape",
        "allowedShapes": [
          "officialQuantifiedFormula",
          "officialLimitedGuidance"
        ]
      },
      {
        "id": "rule-12",
        "description": "User-facing reciprocity presentation on a launch preset never surfaces the legacy table-era vocabulary (Exact, Estimated, Interpolated, Extrapolated, Advisory) as primary status / badge text. Current vocabulary: No correction, Formula-derived, Beyond source range, No quantified prediction, Outside guidance.",
        "field": "ReciprocityConfidencePresentation.shortLabel",
        "constraint": "noneContains",
        "forbiddenSubstrings": [
          "Exact",
          "Estimated",
          "Interpolated",
          "Extrapolated",
          "Advisory"
        ]
      }
    ]
  },
